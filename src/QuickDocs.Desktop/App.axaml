<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QuickDocs.Desktop.App"
             xmlns:local="using:QuickDocs.Desktop"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://QuickDocs.UI/Styles/Botones.axaml" />
        <StyleInclude Source="avares://QuickDocs.UI/Styles/Formularios.axaml" />
    </Application.Styles>
</Application>