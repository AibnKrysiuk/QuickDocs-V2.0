<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QuickDocs.Desktop.Views.ArticulosView">
    
    <Grid RowDefinitions="Auto, *" Margin="15" Background="Transparent">
        
        <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,15">
            <TextBlock Text="📦 Catálogo de Artículos y Servicios" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Gestione la lista de precios, marcas y unidades de medida de sus productos de forma centralizada." FontSize="13" Foreground="#64748B"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="1.2*, 1.8*" ColumnSpacing="15">
            
            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000" VerticalAlignment="Top">
                <StackPanel Spacing="12">
                    <TextBlock Text="📝 Datos del Ítem" FontSize="14" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,5"/>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="Tipo" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <ComboBox HorizontalAlignment="Stretch" SelectedIndex="0">
                            <ComboBoxItem>📦 Artículo / Producto</ComboBoxItem>
                            <ComboBoxItem>🛠️ Servicio / Mano de Obra</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Nombre / Descripción" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="Ej. Cable Tipo Taller 2x2.5 / Reparación de Alternador"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Marca (Opcional)" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="Ej. Pristis / Kalop"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Precio ($)" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox PlaceholderText="0.00" HorizontalContentAlignment="Right" FontWeight="Bold" Foreground="#10B981"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Unidad de Medida" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <ComboBox HorizontalAlignment="Stretch" SelectedIndex="0">
                                <ComboBoxItem>Unidad (u.)</ComboBoxItem>
                                <ComboBoxItem>Kilogramo (kg)</ComboBoxItem>
                                <ComboBoxItem>Litro (l.)</ComboBoxItem>
                                <ComboBoxItem>Hora (hs)</ComboBoxItem>
                                <ComboBoxItem>Metro (mts)</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0" ColumnSpacing="10">
                        <Button Grid.Column="0" Content="💾 Guardar Ítem" Background="#10B981" Foreground="White" Padding="0,10" CornerRadius="6" FontWeight="SemiBold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Cancelar" Background="#F1F5F9" Foreground="#475569" Padding="15,10" CornerRadius="6" FontWeight="Medium"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000">
                <Grid RowDefinitions="Auto, Auto, *">
                    
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="10" Margin="0,0,0,15">
                        <TextBox Grid.Column="0" PlaceholderText="🔍 Buscar por nombre, marca o tipo..."/>
                        <Button Grid.Column="1" Content="Limpiar" Background="#F1F5F9" Foreground="#475569" Padding="12,8" CornerRadius="6" FontSize="12"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="2*, *, Auto" Margin="5,0,5,5">
                        <TextBlock Grid.Column="0" Text="Descripción / Detalles" FontWeight="SemiBold" Foreground="#334155" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="Precio / Unidad" FontWeight="SemiBold" Foreground="#334155" FontSize="12" HorizontalAlignment="Right" Margin="0,0,20,0"/>
                        <TextBlock Grid.Column="2" Text="Acciones" FontWeight="SemiBold" Foreground="#334155" FontSize="12" Width="100" HorizontalAlignment="Center"/>
                    </Grid>
                    <Separator Grid.Row="1" VerticalAlignment="Bottom" Background="#E2E8F0"/>

                    <ScrollViewer Grid.Row="2" Margin="0,5,0,0">
                        <StackPanel Spacing="8">
                            
                            <Grid ColumnDefinitions="2*, *, Auto" Margin="5,4">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Tornillo Hexagonal 1/4 x 2" FontWeight="SemiBold" Foreground="#0F172A" FontSize="13"/>
                                    <TextBlock Text="🏷️ Aceros Max • 📦 Artículo" Foreground="#64748B" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right" Margin="0,0,20,0">
                                    <TextBlock Text="$ 150,00" Foreground="#10B981" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right"/>
                                    <TextBlock Text="por Unidad (u.)" Foreground="#64748B" FontSize="11" HorizontalAlignment="Right"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" Width="100" HorizontalAlignment="Center">
                                    <Button Content="✏️" Background="#E0F2FE" Foreground="#0369A1" Padding="8,4" FontSize="12" CornerRadius="4"/>
                                    <Button Content="🗑️" Background="#FEE2E2" Foreground="#991B1B" Padding="8,4" FontSize="12" CornerRadius="4"/>
                                </StackPanel>
                            </Grid>
                            <Separator Background="#F8FAFC" Margin="0"/>

                            <Grid ColumnDefinitions="2*, *, Auto" Margin="5,4">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Mano de Obra Instalación Eléctrica" FontWeight="SemiBold" Foreground="#0F172A" FontSize="13"/>
                                    <TextBlock Text="🏷️ Sin Marca • 🛠️ Servicio" Foreground="#64748B" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right" Margin="0,0,20,0">
                                    <TextBlock Text="$ 8.500,00" Foreground="#10B981" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right"/>
                                    <TextBlock Text="por Hora (hs)" Foreground="#64748B" FontSize="11" HorizontalAlignment="Right"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" Width="100" HorizontalAlignment="Center">
                                    <Button Content="✏️" Background="#E0F2FE" Foreground="#0369A1" Padding="8,4" FontSize="12" CornerRadius="4"/>
                                    <Button Content="🗑️" Background="#FEE2E2" Foreground="#991B1B" Padding="8,4" FontSize="12" CornerRadius="4"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            
        </Grid>
    </Grid>
</UserControl>