<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             x:Class="QuickDocs.Desktop.Views.InicioView">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="25" Margin="20">
            
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="¡Bienvenido a QuickDocs!" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Este es el estado actual de su gestión comercial." FontSize="14" Foreground="#475569"/>
                </StackPanel>
                
                <Border Grid.Column="1" Background="#E2E8F0" Padding="12,8" CornerRadius="6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📅" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:dd \'de\' MMMM}'}" 
                                   FontWeight="Medium" 
                                   Foreground="#334155" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*, *, *"/>
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="20">
    
                <Border Grid.Column="0" Background="White" Padding="20" CornerRadius="10" BoxShadow="0 4 6 -1 #10000000, 0 2 4 -1 #06000000">
                    <Grid RowDefinitions="Auto, Auto, Auto">
                        <TextBlock Grid.Row="0" Text="Total Facturado (Mes)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock Grid.Row="1" Text="$ 128.500,00" FontSize="24" FontWeight="Bold" Foreground="#10B981" Margin="0,10,0,5"/>
                        <TextBlock Grid.Row="2" Text="📈 +12% respecto al mes pasado" FontSize="11" Foreground="#10B981"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" Padding="20" CornerRadius="10" BoxShadow="0 4 6 -1 #10000000, 0 2 4 -1 #06000000">
                    <Grid RowDefinitions="Auto, Auto, Auto">
                        <TextBlock Grid.Row="0" Text="Documentos Emitidos" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock Grid.Row="1" Text="42" FontSize="24" FontWeight="Bold" Foreground="#3B82F6" Margin="0,10,0,5"/>
                        <TextBlock Grid.Row="2" Text="📄 Presupuestos, Recibos y Remitos" FontSize="11" Foreground="#64748B"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="White" Padding="20" CornerRadius="10" BoxShadow="0 4 6 -1 #10000000, 0 2 4 -1 #06000000">
                    <Grid RowDefinitions="Auto, Auto, Auto">
                        <TextBlock Grid.Row="0" Text="Clientes en Base de Datos" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock Grid.Row="1" Text="18" FontSize="24" FontWeight="Bold" Foreground="#6366F1" Margin="0,10,0,5"/>
                        <TextBlock Grid.Row="2" Text="👥 Sincronizados correctamente" FontSize="11" Foreground="#6366F1"/>
                    </Grid>
                </Border>
                
            </Grid>

            <Grid ColumnDefinitions="*, 1.5*">
                
                <StackPanel Grid.Column="0" Spacing="15" Margin="0,0,20,0">
                    <TextBlock Text="Accesos Rápidos" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                    
                    <Button HorizontalAlignment="Stretch" Padding="15" Background="#F1F5F9" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <TextBlock Text="📄" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Nuevo Presupuesto" FontWeight="SemiBold" Foreground="#0F172A" FontSize="14"/>
                                <TextBlock Text="Cotizar productos o servicios" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button HorizontalAlignment="Stretch" Padding="15" Background="#F1F5F9" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <TextBlock Text="👥" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Registrar Cliente" FontWeight="SemiBold" Foreground="#0F172A" FontSize="14"/>
                                <TextBlock Text="Dar de alta en la base de datos" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Column="1" Background="White" Padding="20" CornerRadius="10" BoxShadow="0 4 6 -1 #10000000">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Últimos Documentos Generados" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                        
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,5">
                                <Border Grid.Column="0" Background="#E0F2FE" Width="36" Height="36" CornerRadius="18">
                                    <TextBlock Text="📄" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="Presupuesto #0004" FontWeight="SemiBold" Foreground="#334155" FontSize="13"/>
                                    <TextBlock Text="Cliente Genérico S.A." Foreground="#64748B" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="$ 45.000,00" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center" FontSize="13"/>
                            </Grid>
                            <Separator Background="#F1F5F9" Margin="0"/>

                            <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,5">
                                <Border Grid.Column="0" Background="#D1FAE5" Width="36" Height="36" CornerRadius="18">
                                    <TextBlock Text="🧾" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="Recibo de Caja #0012" FontWeight="SemiBold" Foreground="#334155" FontSize="13"/>
                                    <TextBlock Text="Juan Pérez" Foreground="#64748B" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="$ 12.800,00" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center" FontSize="13"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>