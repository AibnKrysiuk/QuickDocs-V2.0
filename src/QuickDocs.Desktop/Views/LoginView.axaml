<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuickDocs.Desktop.ViewModels"
        x:Class="QuickDocs.Desktop.Views.LoginView"
        x:DataType="vm:LoginViewModel"
        Title="QuickDocs - Iniciar Sesión"
        Width="400" Height="520"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#F3F4F6">

    <Design.DataContext>
        <vm:LoginViewModel/>
    </Design.DataContext>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" 
                CornerRadius="8" 
                Padding="25" 
                Width="340"
                BoxShadow="0 4 10 0 #20000000">
            
            <StackPanel Spacing="15">
                
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,5">
                    <TextBlock Text="🚀 QuickDocs" 
                               FontSize="26" 
                               FontWeight="Bold" 
                               Foreground="#1F2937"/>
                    <TextBlock Text="Gestión Express para tu Negocio" 
                               FontSize="12" 
                               Foreground="#6B7280" 
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Separator Background="#E5E7EB" Margin="0,2"/>

                <StackPanel Spacing="5">
                    <TextBlock Text="Usuario" FontWeight="Medium" Foreground="#4B5563" FontSize="13"/>
                    <TextBox Text="{Binding Usuario, Mode=TwoWay}" 
                             PlaceholderText="Ej: admin"
                             Padding="10,8"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Contraseña" FontWeight="Medium" Foreground="#4B5563" FontSize="13"/>
                    <TextBox Text="{Binding Contrasena, Mode=TwoWay}" 
                             PasswordChar="●" 
                             PlaceholderText="••••••••"
                             Padding="10,8"/>
                </StackPanel>

                <CheckBox IsChecked="{Binding RecordarSesion}" 
                          Content="Recordar mi sesión" 
                          FontSize="13" 
                          Foreground="#4B5563"/>

                <TextBlock Text="{Binding MensajeError}" 
                           Foreground="#EF4444" 
                           FontSize="12" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Button Click="OnIngresarClick" 
                        Content="Iniciar Sesión" 
                        Background="#2563EB" 
                        Foreground="White" 
                        FontWeight="Bold"
                        FontSize="14"
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center"
                        Padding="0,12"
                        Margin="0,10,0,0"
                        CornerRadius="5"/>

                <Button Click="OnIrARegistroClick" 
                        Content="¿No tenés usuario? Create una cuenta" 
                        Background="Transparent" 
                        Foreground="#4B5563" 
                        FontSize="12"
                        HorizontalAlignment="Center" 
                        Margin="0,5,0,0"/>
                
            </StackPanel>
        </Border>
    </Grid>
</Window>