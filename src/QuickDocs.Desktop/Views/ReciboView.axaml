<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QuickDocs.Desktop.Views.ReciboView">
    
    <Grid RowDefinitions="Auto, *, Auto" Margin="15" Background="Transparent">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0" Spacing="5">
                <TextBlock Text="🧾 Nuevo Recibo de Pago" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Complete los datos del cobro para emitir el comprobante." FontSize="13" Foreground="#64748B"/>
            </StackPanel>
            
            <Button Grid.Column="1" Content="📋 Ver Historial" 
                    Background="#64748B" Foreground="White" 
                    Padding="12,8" CornerRadius="6" FontSize="13" FontWeight="Medium"
                    VerticalAlignment="Top"/>
        </Grid>

        <Border Grid.Row="1" Background="White" Padding="25" CornerRadius="10" BoxShadow="0 4 6 -1 #10000000, 0 2 4 -1 #06000000" VerticalAlignment="Top">
            <StackPanel Spacing="20">
                
                <Grid ColumnDefinitions="2*, *" ColumnSpacing="20">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Recibí de (Cliente / Razón Social)" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="Nombre de la persona o empresa..." HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="La suma de (Monto en $)" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="0.00" HorizontalContentAlignment="Right" FontWeight="Bold" Foreground="#10B981"/>
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="5">
                    <TextBlock Text="En concepto de (Detalle del pago)" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                    <TextBox PlaceholderText="Ej. Cancelación de saldo / Pago entrega de mercadería..." 
                             HorizontalAlignment="Stretch" 
                             Height="80" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Text="* Los datos de la empresa emisora y la fecha actual se incluirán automáticamente al generar el documento." 
                           FontSize="11" 
                           Foreground="#94A3B8" 
                           FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,20,0,0">
            <Button Grid.Column="0" Content="⚙️ Generar Recibo e Imprimir" 
                    Background="#10B981" Foreground="White" 
                    Padding="24,14" FontSize="15" FontWeight="Bold" CornerRadius="6" 
                    HorizontalAlignment="Left"/>
        </Grid>
        
    </Grid>
</UserControl>