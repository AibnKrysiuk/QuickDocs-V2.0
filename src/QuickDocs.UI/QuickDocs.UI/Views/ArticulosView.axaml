<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuickDocs.UI.ViewModels"
             x:Class="QuickDocs.UI.Views.ArticulosView"
             x:DataType="vm:ArticulosViewModel">
    
    <Grid RowDefinitions="Auto, *" Margin="15" Background="Transparent">
        
        <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,15">
            <TextBlock Text="📦 Catálogo de Artículos y Servicios" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Gestione la lista de precios, marcas y unidades de medida de sus productos de forma centralizada." FontSize="13" Foreground="#64748B"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="1.2*, 1.8*" ColumnSpacing="15">
            
            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000" VerticalAlignment="Top">
                <StackPanel Spacing="12">
                    <TextBlock Text="📝 Datos del Ítem" FontSize="14" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,5"/>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="Tipo" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <ComboBox HorizontalAlignment="Stretch" 
                                  ItemsSource="{Binding TiposItem}" 
                                  SelectedItem="{Binding TipoSeleccionado}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Nombre / Descripción" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox Text="{Binding Descripcion, Mode=TwoWay}" PlaceholderText="Ej. Cable Tipo Taller 2x2.5 / Reparación de Alternador"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Marca (Opcional)" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox Text="{Binding Marca, Mode=TwoWay}" PlaceholderText="Ej. Pristis / Kalop"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Precio ($)" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox Text="{Binding PrecioUnitario, Mode=TwoWay}" PlaceholderText="0.00" HorizontalContentAlignment="Right" FontWeight="Bold" Foreground="#10B981"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Unidad de Medida" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <ComboBox HorizontalAlignment="Stretch" 
                                      ItemsSource="{Binding UnidadesMedida}" 
                                      SelectedItem="{Binding UnidadSeleccionada}"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0" ColumnSpacing="10">
                        <Button Grid.Column="0" Content="💾 Guardar Ítem" Command="{Binding GuardarItemCommand}" Background="#10B981" Foreground="White" Padding="0,10" CornerRadius="6" FontWeight="SemiBold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Cancelar" Command="{Binding LimpiarFormularioCommand}" Background="#F1F5F9" Foreground="#475569" Padding="15,10" CornerRadius="6" FontWeight="Medium"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000">
                <Grid RowDefinitions="Auto, Auto, *">
                    
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="10" Margin="0,0,0,15">
                        <TextBox Grid.Column="0" Text="{Binding TextoBuscar, Mode=TwoWay}" PlaceholderText="🔍 Buscar por nombre, marca o tipo..."/>
                        <Button Grid.Column="1" Content="Limpiar" Command="{Binding LimpiarFormularioCommand}" Background="#F1F5F9" Foreground="#475569" Padding="12,8" CornerRadius="6" FontSize="12"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="2*, *, Auto" Margin="5,0,5,5">
                        <TextBlock Grid.Column="0" Text="Descripción / Detalles" FontWeight="SemiBold" Foreground="#334155" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="Precio / Unidad" FontWeight="SemiBold" Foreground="#334155" FontSize="12" HorizontalAlignment="Right" Margin="0,0,20,0"/>
                        <TextBlock Grid.Column="2" Text="Acciones" FontWeight="SemiBold" Foreground="#334155" FontSize="12" Width="100" HorizontalAlignment="Center"/>
                    </Grid>
                    <Separator Grid.Row="1" VerticalAlignment="Bottom" Background="#E2E8F0"/>

                    <ListBox Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding ItemSeleccionado, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Margin="0,5,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="2*, *, Auto" Margin="0,4">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Descripcion}" FontWeight="SemiBold" Foreground="#0F172A" FontSize="13"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="🏷️" FontSize="11"/>
                                            <TextBlock Text="{Binding Marca, TargetNullValue='Sin Marca'}" Foreground="#64748B" FontSize="11"/>
                                            <TextBlock Text="•" Foreground="#64748B" FontSize="11"/>
                                            <TextBlock Text="{Binding Tipo}" Foreground="#64748B" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right" Margin="0,0,20,0">
                                        <TextBlock Text="{Binding PrecioUnitario, StringFormat='{}{0:C}'}" Foreground="#10B981" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right"/>
                                        <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Right">
                                            <TextBlock Text="por" Foreground="#64748B" FontSize="11"/>
                                            <TextBlock Text="{Binding UnidadMedida}" Foreground="#64748B" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" Width="100" HorizontalAlignment="Center">
                                        <TextBlock Text="✏️" VerticalAlignment="Center" Margin="5,0"/>
                                        <Button Content="🗑️" 
                                                Command="{Binding $parent[ListBox].((vm:ArticulosViewModel)DataContext).BorrarItemCommand}" 
                                                CommandParameter="{Binding}" 
                                                Background="#FEE2E2" Foreground="#991B1B" Padding="8,4" FontSize="12" CornerRadius="4"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
        </Grid>
    </Grid>
</UserControl>