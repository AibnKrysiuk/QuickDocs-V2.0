<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuickDocs.UI.ViewModels"
             x:Class="QuickDocs.UI.Views.ClientesView"
             x:DataType="vm:ClientesViewModel">
    
    <Grid RowDefinitions="Auto, *" Margin="15" Background="Transparent">
        
        <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="👥" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                <TextBlock Text="Base de Datos de Clientes" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Administre la información de contacto y facturación de sus clientes en un solo lugar." FontSize="13" Foreground="#64748B"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="1.2*, 1.8*" ColumnSpacing="15">
            
            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000" VerticalAlignment="Top">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,5">
                        <TextBlock Text="📝" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="14" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        <TextBlock Text="Datos del Cliente" FontSize="14" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="Nombre / Razón Social" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="Ej. Juan Pérez / Construcciones S.A." 
                                 Text="{Binding Nombre, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="CUIT / CUIL" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="Ej. 20-34567890-9" 
                                 Text="{Binding CuitCuil, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Correo Electrónico" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="Ej. contacto@empresa.com" 
                                 Text="{Binding Email, Mode=TwoWay}"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Teléfono" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox PlaceholderText="Ej. 11 4444-5555" 
                                     Text="{Binding Telefono, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Teléfono 2 (Opcional)" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox PlaceholderText="Ej. 11 2222-3333"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Dirección" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="Ej. Av. Rivadavia 1234, Piso 2" 
                                 Text="{Binding Direccion, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Localidad" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <TextBox PlaceholderText="Ej. San Justo / La Plata" 
                                 Text="{Binding Localidad, Mode=TwoWay}"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,15,0,0" ColumnSpacing="10">
                        <Button Grid.Column="0" 
                                Command="{Binding GuardarClienteCommand}"
                                Classes="btn-success"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="💾" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                                <TextBlock Text="Guardar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                                
                        <Button Grid.Column="1" 
                                Command="{Binding LimpiarFormularioCommand}"
                                Classes="btn-tertiary"
                                IsVisible="{Binding EsEdicion}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="❌" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                                <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000">
                <Grid RowDefinitions="Auto, Auto, *">
                    
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="10" Margin="0,0,0,15">
                        <TextBox Grid.Column="0" PlaceholderText="🔍 Buscar cliente por nombre o CUIT..." 
                                Text="{Binding TextoBuscar, Mode=TwoWay}" VerticalAlignment="Center"/>
                        
                        <Button Grid.Column="1" 
                                Command="{Binding LimpiarFiltrosCommand}" 
                                Classes="btn-secondary" 
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="🧹" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                                <TextBlock Text="Limpiar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="2*, *, 100" Margin="5,0,5,5">
                        <TextBlock Grid.Column="0" Text="Cliente / Localidad" FontWeight="SemiBold" Foreground="#334155" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="CUIT / Teléfono" FontWeight="SemiBold" Foreground="#334155" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="Acciones" FontWeight="SemiBold" Foreground="#334155" FontSize="12" HorizontalAlignment="Center"/>
                    </Grid>
                    <Separator Grid.Row="1" VerticalAlignment="Bottom" Background="#E2E8F0"/>

                    <ListBox Grid.Row="2" ItemsSource="{Binding Clientes}" 
                            SelectedItem="{Binding ClienteSeleccionado, Mode=TwoWay}"
                            Background="Transparent" BorderThickness="0" Margin="0,5,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="2*, *, 100" Margin="0,4">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" Foreground="#0F172A" FontSize="13"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="📍" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Localidad}" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{Binding CuitCuil}" Foreground="#334155" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="📞" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Telefono}" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Command="{Binding $parent[ListBox].((vm:ClientesViewModel)DataContext).BorrarClienteCommand}"
                                                CommandParameter="{Binding}"
                                                Classes="btn-danger-compact"
                                                Width="32" Height="32" Padding="0"
                                                ToolTip.Tip="Borrar Cliente">
                                            <TextBlock Text="🗑️" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                </Grid>
            </Border>
            
        </Grid>
    </Grid>
</UserControl>