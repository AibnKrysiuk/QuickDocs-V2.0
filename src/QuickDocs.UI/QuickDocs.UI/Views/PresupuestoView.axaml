<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuickDocs.UI.ViewModels"
             x:Class="QuickDocs.UI.Views.PresupuestoView"
             x:DataType="vm:PresupuestoViewModel">
    
    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="15" Background="Transparent">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
            <StackPanel Grid.Column="0" Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="📄" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                    <TextBlock Text="Nuevo Presupuesto" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="Cargue los datos del cliente y los artículos para el documento." FontSize="13" Foreground="#64748B"/>
            </StackPanel>
            
            <Button Grid.Column="1" 
                    Command="{Binding NavegarAHistorialCommand}"
                    Classes="btn-secondary"
                    FontSize="13" FontWeight="Medium"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="📋" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                    <TextBlock Text="Historial" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000" Margin="0,0,0,15">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="20">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Cliente / Razón Social" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <AutoCompleteBox Text="{Binding TextoBuscarCliente, Mode=TwoWay}" 
                            ItemsSource="{Binding SugerenciasClientes}"
                            FilterMode="Contains"
                            PlaceholderText="Escriba el nombre del cliente o empresa..." 
                            HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Documento válido por" FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding DiasValidez, Mode=TwoWay}" Width="50" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text="días." FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="1*, 2*" ColumnSpacing="15">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="CUIT / CUIL (Opcional)" FontSize="11" Foreground="#64748B"/>
                        <TextBox Text="{Binding ClienteCuitLibre, Mode=TwoWay}" 
                                 PlaceholderText="Ej. 20-XXXXXXXX-9"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="Dirección Comercial (Opcional)" FontSize="11" Foreground="#64748B"/>
                        <TextBox Text="{Binding ClienteDireccionLibre, Mode=TwoWay}" 
                                 PlaceholderText="Ej. Av. 7 nro 123, La Plata"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000" Margin="0,0,0,15">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="📥" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="13" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock Text="Ingresar Artículo / Servicio" FontSize="13" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Grid ColumnDefinitions="2*, 1*, 80, 120, Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Nombre / Descripción" FontSize="11" Foreground="#475569"/>
                        <AutoCompleteBox Text="{Binding TextoBuscarItem, Mode=TwoWay}" 
                            ItemsSource="{Binding SugerenciasItems}"
                            FilterMode="Contains"
                            PlaceholderText="Ej. Tornillo Hexagonal o busque en catálogo..."/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="Marca" FontSize="11" Foreground="#475569"/>
                        <TextBox Text="{Binding MarcaRenglon, Mode=TwoWay}" PlaceholderText="Ej. Aceros Max"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Spacing="5">
                        <TextBlock Text="Cant." FontSize="11" Foreground="#475569"/>
                        <TextBox Text="{Binding CantidadRenglon, Mode=TwoWay}" PlaceholderText="0" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="3" Spacing="5">
                        <TextBlock Text="Precio Unit." FontSize="11" Foreground="#475569"/>
                        <TextBox Text="{Binding PrecioRenglon, Mode=TwoWay}" PlaceholderText="0.00" HorizontalContentAlignment="Right"/>
                    </StackPanel>
                    
                    <Button Grid.Column="4" 
                            Command="{Binding AgregarRenglonCommand}"
                            Classes="btn-primary-compact"
                            VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="➕" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Agregar" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="5" BoxShadow="0 2 4 0 #10000000">
            <Grid RowDefinitions="Auto, *, Auto" RowSpacing="10">
                
                <Grid Grid.Row="0" ColumnDefinitions="2*, 1*, 80, 120, 120" Margin="5,0,5,5">
                    <TextBlock Grid.Column="0" Text="Detalle del Artículo" FontWeight="SemiBold" Foreground="#334155"/>
                    <TextBlock Grid.Column="1" Text="Marca" FontWeight="SemiBold" Foreground="#334155"/>
                    <TextBlock Grid.Column="2" Text="Cant." FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Unitario" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="4" Text="Subtotal" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                </Grid>
                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0"/>

                <ListBox Grid.Row="1" 
                        ItemsSource="{Binding Detalles}" 
                        SelectedItem="{Binding DetalleSeleccionado, Mode=TwoWay}" 
                        PointerPressed="DeseleccionarLista_OnPointerPressed" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Padding="0"
                        MaxHeight="500">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="2*, 1*, 80, 120, 120" Margin="0,2">
                                <TextBlock Grid.Column="0" Text="{Binding Descripcion}" VerticalAlignment="Center" Foreground="#0F172A"/>
                                <TextBlock Grid.Column="1" Text="{Binding Marca}" VerticalAlignment="Center" Foreground="#475569"/>
                                <TextBlock Grid.Column="2" Text="{Binding Cantidad}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#0F172A"/>
                                <TextBlock Grid.Column="3" Text="{Binding PrecioUnitario, StringFormat='{}{0:C}'}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#0F172A"/>
                                <TextBlock Grid.Column="4" Text="{Binding Importe, StringFormat='{}{0:C}'}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Medium" Foreground="#0F172A"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            Spacing="10" 
                            HorizontalAlignment="Left" 
                            Margin="0,5,0,0"
                            IsVisible="{Binding DetalleSeleccionado, Converter={x:Static ObjectConverters.IsNotNull}}">
                    
                    <Button Command="{Binding SeleccionarRenglonParaModificarCommand}" 
                            Classes="btn-secondary-compact">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="✏️" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                            <TextBlock Text="Editar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                            
                    <Button Command="{Binding QuitarRenglonCommand}" 
                            Classes="btn-danger-compact">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="🗑️" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                            <TextBlock Text="Quitar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
            </Grid>
        </Border>

        <Grid Grid.Row="4" ColumnDefinitions="*, Auto" Margin="0,15,0,0">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left">
                <Button Command="{Binding GuardarPresupuestoCommand}"
                        Classes="btn-success">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⚙️" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                        <TextBlock Text="Emitir" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding ConvertirARemitoCommand}"
                        IsVisible="{Binding EsEdicion}"
                        Classes="btn-accent">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🚚" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                        <TextBlock Text="Convertir" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                <TextBlock Text="TOTAL:" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Total, StringFormat='{}{0:C}'}" FontSize="26" FontWeight="Black" Foreground="#10B981" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        
    </Grid>
</UserControl>