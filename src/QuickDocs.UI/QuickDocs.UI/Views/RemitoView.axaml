<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuickDocs.UI.ViewModels"
             x:Class="QuickDocs.UI.Views.RemitoView"
             x:DataType="vm:RemitoViewModel">
    
    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="15" Background="Transparent">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
            <StackPanel Grid.Column="0" Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="🚚" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                    <TextBlock Text="Nuevo Remito de Entrega" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="Gestione el traslado y la constancia de recepción de mercaderías." FontSize="13" Foreground="#64748B"/>
            </StackPanel>
            
            <Button Grid.Column="1" 
                    Command="{Binding NavegarAHistorialCommand}"
                    Classes="btn-secondary"
                    FontSize="13" FontWeight="Medium"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="📋" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                    <TextBlock Text="Historial" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000" Margin="0,0,0,15">
            <Grid RowDefinitions="Auto, Auto" RowSpacing="15">
                
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="20">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Destinatario / Cliente" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <AutoCompleteBox Text="{Binding TextoBuscarCliente, Mode=TwoWay}" 
                                        ItemsSource="{Binding SugerenciasClientes}"
                                        FilterMode="Contains"
                                        PlaceholderText="Escriba para buscar o registrar cliente manual..." 
                                        HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                Spacing="8" 
                                VerticalAlignment="Bottom" 
                                Margin="0,0,0,8">
                        
                        <CheckBox IsChecked="{Binding MostrarPreciosImpresion, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                Margin="0"/>
                        
                        <TextBlock Text="Mostrar precios en el documento impreso" 
                                FontSize="13" 
                                FontWeight="Medium" 
                                Foreground="#334155" 
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="5">
                    <TextBlock Text="📍 Lugar de Entrega / Dirección de Envío" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                    <TextBox Text="{Binding DireccionEntrega, Mode=TwoWay}" 
                            PlaceholderText="Ej. Av. Siempreviva 742, Planta Alta / Dejar en depósito central..." HorizontalAlignment="Stretch"/>
                </StackPanel>
                
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 4 0 #10000000" Margin="0,0,0,15">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="📦" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="13" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock Text="Añadir Bultos / Artículos al Remito" FontSize="13" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Grid ColumnDefinitions="*, 120, 100, Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Descripción del artículo" FontSize="11" Foreground="#475569"/>
                        <AutoCompleteBox Text="{Binding TextoBuscarItem, Mode=TwoWay}"
                                         ItemsSource="{Binding SugerenciasItems}"
                                         FilterMode="Contains"
                                         PlaceholderText="Ej. Pack de Ladrillos..."/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="Marca" FontSize="11" Foreground="#475569"/>
                        <TextBox Text="{Binding MarcaRenglon, Mode=TwoWay}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="5">
                        <TextBlock Text="Cant." FontSize="11" Foreground="#475569"/>
                        <TextBox Text="{Binding CantidadRenglon, Mode=TwoWay}" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="3" 
                            Command="{Binding AgregarRenglonCommand}"
                            Classes="btn-primary-compact"
                            VerticalAlignment="Bottom" 
                            FontSize="13">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="➕" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Agregar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="5" BoxShadow="0 2 4 0 #10000000">
            <Grid RowDefinitions="Auto, *, Auto" RowSpacing="10">
                
                <Grid Grid.Row="0" ColumnDefinitions="*, 150, 100" Margin="5,0,5,5">
                    <TextBlock Grid.Column="0" Text="Detalle del Artículo enviado" FontWeight="SemiBold" Foreground="#334155"/>
                    <TextBlock Grid.Column="1" Text="Marca" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Cant." FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Center"/>
                </Grid>
                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E2E8F0"/>

                <ListBox Grid.Row="1" 
                        ItemsSource="{Binding Detalles}" 
                        SelectedItem="{Binding DetalleSeleccionado, Mode=TwoWay}"
                        PointerPressed="DeseleccionarLista_OnPointerPressed"
                        Background="Transparent" 
                        BorderThickness="0"
                        Padding="0"
                        MaxHeight="500">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, 150, 100" Margin="0,2">
                                <TextBlock Grid.Column="0" Text="{Binding Descripcion}" VerticalAlignment="Center" Foreground="#0F172A"/>
                                <TextBlock Grid.Column="1" Text="{Binding Marca}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#475569"/>
                                <TextBlock Grid.Column="2" Text="{Binding Cantidad}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#0F172A"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            Spacing="10" 
                            HorizontalAlignment="Left" 
                            Margin="0,5,0,0"
                            IsVisible="{Binding DetalleSeleccionado, Converter={x:Static ObjectConverters.IsNotNull}}">
                    
                    <Button Command="{Binding SeleccionarRenglonParaModificarCommand}"
                            Classes="btn-secondary-compact">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="✏️" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                            <TextBlock Text="Editar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding QuitarRenglonCommand}"
                            Classes="btn-danger-compact">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="🗑️" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                            <TextBlock Text="Quitar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4" ColumnDefinitions="*, Auto" Margin="0,15,0,0">
            <Button Grid.Column="0" 
                    Command="{Binding GuardarRemitoCommand}" 
                    Classes="btn-success"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="⚙️" FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji" VerticalAlignment="Center"/>
                    <TextBlock Text="Emitir" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
        
    </Grid>
</UserControl>